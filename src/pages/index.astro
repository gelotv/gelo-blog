---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("posts"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const postPath = (post: (typeof posts)[number]) =>
  `/posts/${post.id.replace(/\.(md|mdx)$/, "")}/`;

const formatDate = (date: Date) =>
  date.toLocaleDateString("pt-BR", {
    day: "2-digit",
    month: "short",
    year: "numeric",
  });
---

<BaseLayout>
  <main>
    <section class="blog-hero">
      <div class="blog-hero__content">
        <div>
          <img
            alt=""
            aria-hidden="true"
            class="blog-hero__mark"
            decoding="async"
            src="/brand/gelo_icon_blue.svg"
          />
          <p class="eyebrow">blog.gelo.tv</p>
          <h1>Geloblog</h1>
          <p class="blog-hero__lead">
            Novidades, bastidores e guias em português para criadores,
            comunidades e pessoas que acompanham a evolução do Gelo.
          </p>
        </div>
        {
          featuredPost && (
            <a class="featured-post" href={postPath(featuredPost)}>
              <img
                alt={featuredPost.data.thumbnail.alt}
                class="featured-post__image"
                decoding="async"
                src={featuredPost.data.thumbnail.src}
              />
              <div class="featured-post__body">
                <div class="post-card__meta">
                  <span>Destaque</span>
                  <span>{formatDate(featuredPost.data.publishDate)}</span>
                </div>
                <h2>{featuredPost.data.title}</h2>
                <p>{featuredPost.data.description}</p>
              </div>
            </a>
          )
        }
      </div>
    </section>

    <section class="section" aria-labelledby="latest-posts">
      <div class="section-heading section-heading--with-search">
        <div>
          <p class="eyebrow">Publicações</p>
          <h2 id="latest-posts">Últimos posts</h2>
        </div>
        <label class="search-box">
          <span>Buscar</span>
          <input
            autocomplete="off"
            data-post-search
            placeholder="Buscar posts"
            type="search"
          />
        </label>
      </div>

      <div class="post-grid">
        {
          posts.map((post) => (
            <a
              class="post-card"
              data-post-card
              data-search={`${post.data.title} ${post.data.description} ${post.data.category} ${post.data.tags.join(" ")}`.toLowerCase()}
              href={postPath(post)}
            >
              <img
                alt={post.data.thumbnail.alt}
                class="post-card__image"
                decoding="async"
                loading="lazy"
                src={post.data.thumbnail.src}
              />
              <div class="post-card__meta">
                <span>{post.data.category}</span>
                <span>{formatDate(post.data.publishDate)}</span>
              </div>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <div class="post-card__tags">
                {post.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </a>
          ))
        }
      </div>
      <p class="empty-state" data-empty-state hidden>Nenhum post encontrado.</p>
    </section>
  </main>

  <script>
    const input = document.querySelector<HTMLInputElement>("[data-post-search]");
    const cards = Array.from(
      document.querySelectorAll<HTMLElement>("[data-post-card]"),
    );
    const emptyState = document.querySelector<HTMLElement>("[data-empty-state]");

    input?.addEventListener("input", () => {
      const query = input.value.trim().toLowerCase();
      let visibleCount = 0;

      for (const card of cards) {
        const match = card.dataset.search?.includes(query) ?? false;
        card.hidden = !match;
        if (match) visibleCount += 1;
      }

      if (emptyState) {
        emptyState.hidden = visibleCount > 0;
      }
    });
  </script>
</BaseLayout>
