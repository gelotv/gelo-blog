---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import { assetPath } from "../lib/paths";
import { absoluteUrl, currentUrl, siteName } from "../lib/seo";

type Props = {
  post: CollectionEntry<"posts">;
  relatedPosts?: CollectionEntry<"posts">[];
};

const { post, relatedPosts = [] } = Astro.props;
const postPath = (entry: CollectionEntry<"posts">) =>
  assetPath(`/posts/${entry.id.replace(/\.(md|mdx)$/, "")}/`);
const date = post.data.publishDate.toLocaleDateString("pt-BR", {
  day: "2-digit",
  month: "long",
  year: "numeric",
});
const postUrl = currentUrl(Astro.url.pathname, Astro.site);
const imageUrl = absoluteUrl(post.data.thumbnail.src, Astro.site);
const updatedDate = post.data.updatedDate ?? post.data.publishDate;
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "@id": `${postUrl}#article`,
    mainEntityOfPage: postUrl,
    headline: post.data.title,
    description: post.data.description,
    image: [imageUrl],
    datePublished: post.data.publishDate.toISOString(),
    dateModified: updatedDate.toISOString(),
    inLanguage: "pt-BR",
    articleSection: post.data.category,
    keywords: post.data.tags,
    author: {
      "@type": "Organization",
      name: post.data.author,
      url: "https://gelo.tv",
    },
    publisher: {
      "@type": "Organization",
      name: "Gelo",
      url: "https://gelo.tv",
      logo: {
        "@type": "ImageObject",
        url: absoluteUrl("/brand/gelo_icon_blue.svg", Astro.site),
      },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: siteName,
        item: currentUrl(assetPath("/"), Astro.site),
      },
      {
        "@type": "ListItem",
        position: 2,
        name: post.data.title,
        item: postUrl,
      },
    ],
  },
];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.thumbnail.src}
  type="article"
  publishedTime={post.data.publishDate}
  modifiedTime={updatedDate}
  author={post.data.author}
  tags={post.data.tags}
  jsonLd={jsonLd}
>
  <main class="post-shell">
    <article>
      <header class="post-header">
        <div class="post-header__meta">
          <span>{post.data.category}</span>
          <span>{date}</span>
          <span>{post.data.author}</span>
        </div>
        <h1>{post.data.title}</h1>
        <p class="post-header__lead">{post.data.description}</p>
      </header>

      <img
        alt={post.data.thumbnail.alt}
        class="post-cover"
        decoding="async"
        src={assetPath(post.data.thumbnail.src)}
      />

      <div class="post-body">
        <slot />
      </div>

      {
        relatedPosts.length > 0 && (
          <section class="related-posts" aria-labelledby="related-posts">
            <div class="section-heading">
              <p class="eyebrow">Relacionados</p>
              <h2 id="related-posts">Leia também</h2>
            </div>
            <div class="post-grid">
              {relatedPosts.map((relatedPost) => (
                <a class="post-card" href={postPath(relatedPost)}>
                  <img
                    alt={relatedPost.data.thumbnail.alt}
                    class="post-card__image"
                    decoding="async"
                    loading="lazy"
                    src={assetPath(relatedPost.data.thumbnail.src)}
                  />
                  <div class="post-card__meta">
                    <span>{relatedPost.data.category}</span>
                  </div>
                  <h2>{relatedPost.data.title}</h2>
                  <p>{relatedPost.data.description}</p>
                </a>
              ))}
            </div>
          </section>
        )
      }

      <nav aria-label="Navegação do post" class="post-nav">
        <a href={assetPath("/")}>Voltar para o blog</a>
        <a href="https://gelo.tv">Abrir gelo.tv</a>
      </nav>
    </article>
  </main>
</BaseLayout>
